@using Sandbox
@using Sandbox.UI
@inherits PanelComponent

<root>
    <style>
        .board-panel {
            position: absolute;
            width: 100%;
            height: 100%;
            pointer-events: all;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: rgba(0, 0, 0, 0.92);
        }

        .board-panel.hidden {
            display: none;
        }

        .board-container {
            width: 1200px;
            max-height: 860px;
            background-color: rgb(8, 10, 28);
            border: 2px solid rgba(0, 180, 220, 0.7);
            border-radius: 6px;
            flex-direction: column;
            overflow: hidden;
            box-shadow: 0 0 80px rgba(0, 160, 220, 0.3);
        }

        /* === HEADER === */
        .board-header {
            flex-direction: row;
            justify-content: space-between;
            align-items: center;
            padding: 22px 36px;
            background-color: rgba(0, 30, 60, 0.6);
            border-bottom: 2px solid rgba(0, 180, 220, 0.5);
        }

        .board-header-left {
            flex-direction: column;
        }

        .board-title {
            font-size: 32px;
            font-weight: 900;
            color: rgb(180, 230, 255);
            letter-spacing: 6px;
            font-family: Consolas;
        }

        .board-subtitle {
            font-size: 13px;
            color: rgba(0, 180, 220, 0.5);
            letter-spacing: 4px;
            margin-top: 3px;
            font-family: Consolas;
        }

        .player-count-badge {
            flex-direction: row;
            align-items: center;
            gap: 8px;
            padding: 8px 18px;
            background-color: rgba(0, 120, 180, 0.1);
            border: 1px solid rgba(0, 180, 220, 0.3);
            border-radius: 4px;
        }

        .player-count-text {
            font-size: 16px;
            font-weight: 700;
            color: rgb(0, 200, 240);
            font-family: Consolas;
            letter-spacing: 1px;
        }

        .player-count-label {
            font-size: 12px;
            color: rgba(0, 180, 220, 0.5);
            font-family: Consolas;
            letter-spacing: 2px;
        }

        /* === TABLE HEADER === */
        .table-header {
            flex-direction: row;
            align-items: center;
            padding: 14px 44px;
            background-color: rgba(0, 8, 24, 0.9);
            border-bottom: 1px solid rgba(0, 180, 220, 0.2);
        }

        .col-rank {
            min-width: 80px;
        }

        .col-name {
            flex-grow: 1;
        }

        .col-wins {
            min-width: 160px;
            text-align: center;
            justify-content: center;
        }

        .table-header-text {
            font-size: 12px;
            font-weight: 700;
            color: rgba(0, 200, 240, 0.5);
            letter-spacing: 3px;
            font-family: Consolas;
        }

        /* === PLAYER ROWS === */
        .player-list {
            flex-direction: column;
            flex-grow: 1;
            background-color: rgba(8, 10, 28, 1);
            padding: 10px 0px;
        }

        .player-row {
            flex-direction: row;
            align-items: center;
            padding: 18px 44px;
            border-bottom: 1px solid rgba(0, 180, 220, 0.04);
            transition: all 0.15s;
        }

        .player-row:hover {
            background-color: rgba(0, 80, 140, 0.06);
        }

        .player-row.is-local {
            background-color: rgba(0, 120, 180, 0.08);
            border-left: 3px solid rgba(0, 200, 240, 0.6);
        }

        /* Rank */
        .rank-display {
            min-width: 80px;
            flex-direction: row;
            align-items: center;
            gap: 6px;
        }

        .rank-number {
            font-size: 22px;
            font-weight: 800;
            color: rgba(160, 180, 200, 0.4);
            font-family: Consolas;
            min-width: 36px;
        }

        .rank-first {
            color: rgb(255, 215, 0);
        }

        .rank-second {
            color: rgb(192, 192, 210);
        }

        .rank-third {
            color: rgb(205, 127, 50);
        }

        /* Player Name */
        .player-name-col {
            flex-grow: 1;
            flex-direction: row;
            align-items: center;
            gap: 14px;
        }

        .player-avatar {
            width: 42px;
            height: 42px;
            background-color: rgba(0, 120, 180, 0.15);
            border: 1px solid rgba(0, 180, 220, 0.25);
            border-radius: 4px;
            justify-content: center;
            align-items: center;
        }

        .avatar-letter {
            font-size: 18px;
            font-weight: 800;
            color: rgb(0, 200, 240);
            font-family: Consolas;
        }

        .player-name-text {
            font-size: 18px;
            font-weight: 700;
            color: rgba(210, 225, 240, 0.95);
            font-family: Consolas;
            letter-spacing: 1px;
        }

        .local-tag {
            font-size: 10px;
            font-weight: 700;
            color: rgba(0, 200, 240, 0.6);
            background-color: rgba(0, 120, 180, 0.1);
            border: 1px solid rgba(0, 180, 220, 0.2);
            border-radius: 2px;
            padding: 2px 8px;
            letter-spacing: 1px;
            font-family: Consolas;
        }

        /* Wins */
        .wins-col {
            min-width: 160px;
            flex-direction: row;
            justify-content: center;
            align-items: center;
            gap: 8px;
        }

        .wins-number {
            font-size: 24px;
            font-weight: 800;
            color: rgb(0, 200, 240);
            font-family: Consolas;
        }

        .wins-label {
            font-size: 11px;
            color: rgba(140, 160, 190, 0.4);
            letter-spacing: 1px;
            font-family: Consolas;
        }

        /* Empty Slot */
        .empty-row {
            flex-direction: row;
            align-items: center;
            padding: 18px 44px;
            border-bottom: 1px solid rgba(0, 180, 220, 0.04);
        }

        .empty-rank {
            min-width: 80px;
        }

        .empty-rank-text {
            font-size: 22px;
            font-weight: 800;
            color: rgba(60, 70, 90, 0.3);
            font-family: Consolas;
            min-width: 36px;
        }

        .empty-name {
            flex-grow: 1;
        }

        .empty-text {
            font-size: 15px;
            color: rgba(80, 100, 130, 0.25);
            font-family: Consolas;
            letter-spacing: 1px;
        }

        .empty-dash {
            min-width: 160px;
            justify-content: center;
            align-items: center;
        }

        .empty-dash-text {
            font-size: 16px;
            color: rgba(60, 70, 90, 0.2);
            font-family: Consolas;
        }

        /* === FOOTER === */
        .board-footer {
            padding: 12px 36px;
            background-color: rgba(0, 8, 24, 0.8);
            border-top: 1px solid rgba(0, 180, 220, 0.12);
            flex-direction: row;
            justify-content: center;
            align-items: center;
            gap: 8px;
        }

        .footer-text {
            font-size: 13px;
            color: rgba(120, 140, 170, 0.4);
            font-family: Consolas;
        }

        .footer-key {
            font-size: 12px;
            font-weight: 700;
            color: rgba(0, 200, 240, 0.5);
            background-color: rgba(0, 120, 180, 0.1);
            border: 1px solid rgba(0, 180, 220, 0.2);
            border-radius: 3px;
            padding: 3px 10px;
            font-family: Consolas;
        }
    </style>

    <div class="board-panel @(IsVisible ? "" : "hidden")">
        <div class="board-container">

            <!-- HEADER -->
            <div class="board-header">
                <div class="board-header-left">
                    <label class="board-title">PLAYERS</label>
                    <label class="board-subtitle">CREW MANIFEST — NEXUS-7 STATION</label>
                </div>
                <div class="player-count-badge">
                    <label class="player-count-text">@PlayerCount / 10</label>
                    <label class="player-count-label">CREW</label>
                </div>
            </div>

            <!-- TABLE HEADER -->
            <div class="table-header">
                <div class="col-rank">
                    <label class="table-header-text">RANK</label>
                </div>
                <div class="col-name">
                    <label class="table-header-text">CREW MEMBER</label>
                </div>
                <div class="col-wins">
                    <label class="table-header-text">CITIZEN</label>
                </div>
                <div class="col-wins">
                    <label class="table-header-text">ANOMALY</label>
                </div>
            </div>

            <!-- PLAYER LIST -->
            <div class="player-list">
                @for ( int i = 0; i < 10; i++ )
                {
                    var index = i;
                    if ( index < Players.Count )
                    {
                        var player = Players[index];
                        var rankClass = index == 0 ? "rank-first" : index == 1 ? "rank-second" : index == 2 ? "rank-third" : "";
                        var isLocal = player.IsLocal;
                        var initial = player.Name.Length > 0 ? player.Name.Substring( 0, 1 ).ToUpper() : "?";

                        <div class="player-row @(isLocal ? "is-local" : "")">
                            <div class="rank-display">
                                <label class="rank-number @rankClass">@((index + 1).ToString("00"))</label>
                            </div>
                            <div class="player-name-col">
                                <div class="player-avatar">
                                    @if ( player.SteamId > 0 )
                                    {
                                        <img src="avatar:@player.SteamId" style="width: 100%; height: 100%; border-radius: 3px;" />
                                    }
                                    else
                                    {
                                        <label class="avatar-letter">@initial</label>
                                    }
                                </div>
                                <label class="player-name-text">@player.Name</label>
                                @if ( isLocal )
                                {
                                    <label class="local-tag">YOU</label>
                                }
                            </div>
                            <div class="wins-col">
                                <label class="wins-number" style="color: rgb(80, 220, 120);">@player.CitizenWins</label>
                                <label class="wins-label">WINS</label>
                            </div>
                            <div class="wins-col">
                                <label class="wins-number" style="color: rgb(255, 80, 80);">@player.AnomalyWins</label>
                                <label class="wins-label">WINS</label>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="empty-row">
                            <div class="empty-rank">
                                <label class="empty-rank-text">@((index + 1).ToString("00"))</label>
                            </div>
                            <div class="empty-name">
                                <label class="empty-text">WAITING FOR CREW...</label>
                            </div>
                            <div class="empty-dash">
                                <label class="empty-dash-text">—</label>
                            </div>
                            <div class="empty-dash">
                                <label class="empty-dash-text">—</label>
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- FOOTER -->
            <div class="board-footer">
                <label class="footer-text">Press</label>
                <label class="footer-key">TAB</label>
                <label class="footer-text">to close</label>
            </div>

        </div>
    </div>
</root>

@code {
    public bool IsVisible { get; set; } = false;
    public List<PlayerEntry> Players { get; set; } = new();
    public int PlayerCount => Players.Count;

    protected override void OnUpdate()
    {
        // Toggle with TAB key
        if ( Input.Pressed( "score" ) )
        {
            IsVisible = !IsVisible;
            StateHasChanged();
        }

        // Get data from the bridge
        RefreshPlayers();
    }

    private void RefreshPlayers()
    {
        Players.Clear();

        var bridgeData = PlayerBoardBridge.GetPlayerData();
        
        foreach ( var data in bridgeData )
        {
            var entry = new PlayerEntry
            {
                Name = data.Name,
                CitizenWins = data.CitizenWins,
                AnomalyWins = data.AnomalyWins,
                IsLocal = data.IsLocal,
                SteamId = data.SteamId
            };
            Players.Add( entry );
        }
    }

    protected override int BuildHash()
    {
        return System.HashCode.Combine( IsVisible, PlayerCount );
    }

    public class PlayerEntry
    {
        public string Name { get; set; } = "";
        public int CitizenWins { get; set; } = 0;
        public int AnomalyWins { get; set; } = 0;
        public int TotalWins => CitizenWins + AnomalyWins;
        public bool IsLocal { get; set; } = false;
        public ulong SteamId { get; set; } = 0;
    }
}
