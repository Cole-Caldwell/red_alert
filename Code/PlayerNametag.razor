@using Sandbox;
@using Sandbox.UI;
@inherits PanelComponent

<root>
	<div class="nametag">
		<span class="name">@DisplayName</span>
	</div>
</root>

@code {
	public string DisplayName { get; set; } = "";

	protected override void OnStart()
	{
		DisplayName = GameObject.Root.Name.Replace( "Player - ", "" );
	}

	protected override void OnUpdate()
	{
		DisplayName = GameObject.Root.Name.Replace( "Player - ", "" );

		var cam = Scene.Camera;
		if ( cam is null ) return;

		// Check crouch state from the built-in PlayerController (synced to all clients)
		float nametagHeight = 85f;
		var sboxController = GameObject.Root.Components.Get<Sandbox.PlayerController>();
		if ( sboxController != null && sboxController.IsDucking )
		{
			nametagHeight = 55f;
		}

		WorldPosition = GameObject.Root.WorldPosition + Vector3.Up * nametagHeight;

		// Billboard: always face the camera
		var dirToCamera = cam.WorldPosition - WorldPosition;
		if ( dirToCamera.LengthSquared > 0.01f )
		{
			WorldRotation = Rotation.LookAt( dirToCamera );
		}
	}

	protected override int BuildHash()
	{
		return System.HashCode.Combine( DisplayName );
	}
}