@using Sandbox;
@using Sandbox.UI;
@inherits PanelComponent

<root>
	<style>
		/* === FULL SCREEN OVERLAY === */
		.voting-overlay {
			position: absolute;
			width: 100%;
			height: 100%;
			pointer-events: all;
			display: flex;
			align-items: center;
			justify-content: center;
			background-color: rgba(0, 0, 0, 0.88);
		}

		.voting-overlay.hidden {
			display: none;
		}

		/* === MAIN CONTAINER === */
		.voting-container {
			width: 1400px;
			max-height: 920px;
			background-color: rgb(6, 8, 22);
			border: 2px solid rgba(220, 50, 50, 0.5);
			border-radius: 6px;
			flex-direction: column;
			overflow: hidden;
			box-shadow: 0 0 100px rgba(220, 40, 40, 0.15), 0 0 40px rgba(0, 0, 0, 0.8);
		}

		/* === HEADER === */
		.voting-header {
			flex-direction: column;
			padding: 22px 36px 18px 36px;
			background-color: rgba(40, 8, 8, 0.5);
			border-bottom: 2px solid rgba(220, 50, 50, 0.35);
		}

		.header-top-row {
			flex-direction: row;
			justify-content: space-between;
			align-items: center;
		}

		.header-left {
			flex-direction: column;
		}

		.voting-title {
			font-size: 30px;
			font-weight: 900;
			color: rgb(255, 80, 80);
			letter-spacing: 8px;
			font-family: Consolas;
			text-shadow: 0 0 20px rgba(255, 60, 60, 0.4);
		}

		.voting-subtitle {
			font-size: 12px;
			color: rgba(255, 100, 100, 0.4);
			letter-spacing: 4px;
			margin-top: 4px;
			font-family: Consolas;
		}

		.header-right {
			flex-direction: row;
			align-items: center;
			gap: 16px;
		}

		/* Timer */
		.timer-box {
			flex-direction: column;
			align-items: center;
			padding: 8px 20px;
			background-color: rgba(0, 0, 0, 0.4);
			border: 1px solid rgba(220, 50, 50, 0.3);
			border-radius: 4px;
		}

		.timer-value {
			font-size: 28px;
			font-weight: 900;
			color: rgb(255, 200, 80);
			font-family: Consolas;
			letter-spacing: 2px;
		}

		.timer-label {
			font-size: 10px;
			color: rgba(255, 200, 80, 0.5);
			letter-spacing: 3px;
			font-family: Consolas;
		}

		/* Phase badge */
		.phase-badge {
			padding: 8px 18px;
			border-radius: 4px;
			border: 1px solid;
		}

		.phase-badge.discussion {
			background-color: rgba(255, 180, 40, 0.1);
			border-color: rgba(255, 180, 40, 0.4);
		}

		.phase-badge.voting {
			background-color: rgba(80, 220, 120, 0.1);
			border-color: rgba(80, 220, 120, 0.4);
		}

		.phase-text {
			font-size: 13px;
			font-weight: 800;
			letter-spacing: 3px;
			font-family: Consolas;
		}

		.phase-text.discussion {
			color: rgb(255, 200, 80);
		}

		.phase-text.voting {
			color: rgb(80, 220, 120);
		}

		/* Body info bar */
		.body-info-bar {
			margin-top: 14px;
			padding: 10px 20px;
			background-color: rgba(220, 50, 50, 0.08);
			border: 1px solid rgba(220, 50, 50, 0.15);
			border-radius: 3px;
			flex-direction: row;
			align-items: center;
			gap: 10px;
		}

		.body-info-icon {
			font-size: 16px;
			color: rgba(255, 80, 80, 0.7);
			font-family: Consolas;
		}

		.body-info-text {
			font-size: 14px;
			color: rgba(255, 140, 140, 0.85);
			font-family: Consolas;
			letter-spacing: 1px;
		}

		/* === PLAYER GRID === */
		.player-grid {
			display: flex;
			flex-direction: row;
			flex-wrap: wrap;
			padding: 20px 30px;
			gap: 14px;
			justify-content: center;
			align-items: flex-start;
			flex-grow: 1;
		}

		/* Player card */
		.player-card {
			width: 280px;
			flex-direction: column;
			background-color: rgba(10, 14, 32, 0.95);
			border: 1px solid rgba(0, 140, 200, 0.15);
			border-radius: 5px;
			overflow: hidden;
			transition: all 0.15s;
		}

		.player-card:hover {
			border-color: rgba(0, 180, 220, 0.5);
			background-color: rgba(14, 20, 44, 0.95);
		}

		.player-card.is-dead {
			opacity: 0.35;
			pointer-events: none;
		}

		.player-card.is-voted {
			border-color: rgba(80, 220, 120, 0.6);
			box-shadow: 0 0 20px rgba(80, 220, 120, 0.1);
		}

		.player-card.can-vote {
			cursor: pointer;
		}

		.player-card.can-vote:hover {
			border-color: rgba(255, 80, 80, 0.6);
			box-shadow: 0 0 15px rgba(255, 60, 60, 0.1);
		}

		.card-main {
			flex-direction: row;
			align-items: center;
			padding: 14px 16px;
			gap: 14px;
		}

		/* Avatar */
		.card-avatar {
			width: 52px;
			height: 52px;
			min-width: 52px;
			background-color: rgba(0, 100, 160, 0.12);
			border: 1px solid rgba(0, 180, 220, 0.2);
			border-radius: 4px;
			justify-content: center;
			align-items: center;
			overflow: hidden;
		}

		.card-avatar img {
			width: 100%;
			height: 100%;
		}

		.avatar-initial {
			font-size: 22px;
			font-weight: 900;
			color: rgb(0, 180, 220);
			font-family: Consolas;
		}

		/* Player info */
		.card-info {
			flex-direction: column;
			flex-grow: 1;
			gap: 4px;
			overflow: hidden;
		}

		.card-name {
			font-size: 16px;
			font-weight: 800;
			color: rgba(200, 220, 240, 0.95);
			font-family: Consolas;
			letter-spacing: 1px;
			overflow: hidden;
			white-space: nowrap;
		}

		.card-status {
			font-size: 11px;
			font-weight: 700;
			letter-spacing: 2px;
			font-family: Consolas;
		}

		.card-status.alive {
			color: rgba(80, 220, 120, 0.7);
		}

		.card-status.dead {
			color: rgba(255, 60, 60, 0.6);
		}

		/* Vote indicator on card */
		.card-votes {
			flex-direction: column;
			align-items: center;
			justify-content: center;
			min-width: 44px;
		}

		.vote-count {
			font-size: 22px;
			font-weight: 900;
			color: rgb(255, 80, 80);
			font-family: Consolas;
		}

		.vote-label {
			font-size: 9px;
			color: rgba(255, 80, 80, 0.4);
			letter-spacing: 1px;
			font-family: Consolas;
		}

		/* Your vote confirmation */
		.your-vote-tag {
			padding: 4px 0px;
			background-color: rgba(80, 220, 120, 0.08);
			border-top: 1px solid rgba(80, 220, 120, 0.15);
			justify-content: center;
			align-items: center;
		}

		.your-vote-text {
			font-size: 10px;
			font-weight: 800;
			color: rgba(80, 220, 120, 0.7);
			letter-spacing: 2px;
			font-family: Consolas;
		}

		/* === BOTTOM BAR === */
		.bottom-bar {
			flex-direction: row;
			justify-content: space-between;
			align-items: center;
			padding: 14px 36px;
			background-color: rgba(0, 4, 16, 0.9);
			border-top: 1px solid rgba(0, 180, 220, 0.1);
		}

		.skip-button {
			padding: 10px 28px;
			background-color: rgba(120, 120, 140, 0.08);
			border: 1px solid rgba(160, 160, 180, 0.25);
			border-radius: 4px;
			cursor: pointer;
			transition: all 0.15s;
		}

		.skip-button:hover {
			background-color: rgba(160, 160, 180, 0.12);
			border-color: rgba(200, 200, 220, 0.4);
		}

		.skip-button.disabled {
			opacity: 0.3;
			pointer-events: none;
		}

		.skip-text {
			font-size: 14px;
			font-weight: 800;
			color: rgba(180, 180, 200, 0.7);
			letter-spacing: 3px;
			font-family: Consolas;
		}

		.voted-skip-tag {
			padding: 10px 28px;
			background-color: rgba(80, 220, 120, 0.06);
			border: 1px solid rgba(80, 220, 120, 0.3);
			border-radius: 4px;
		}

		.voted-skip-text {
			font-size: 14px;
			font-weight: 800;
			color: rgba(80, 220, 120, 0.7);
			letter-spacing: 3px;
			font-family: Consolas;
		}

		.toggle-hint {
			flex-direction: row;
			align-items: center;
			gap: 8px;
		}

		.hint-text {
			font-size: 12px;
			color: rgba(120, 140, 170, 0.4);
			font-family: Consolas;
		}

		.hint-key {
			font-size: 11px;
			font-weight: 700;
			color: rgba(0, 200, 240, 0.5);
			background-color: rgba(0, 120, 180, 0.1);
			border: 1px solid rgba(0, 180, 220, 0.2);
			border-radius: 3px;
			padding: 3px 10px;
			font-family: Consolas;
		}
	</style>

	<div class="voting-overlay @(IsVisible ? "" : "hidden")">
		<div class="voting-container">

			<!-- HEADER -->
			<div class="voting-header">
				<div class="header-top-row">
					<div class="header-left">
						<label class="voting-title">EMERGENCY MEETING</label>
						<label class="voting-subtitle">NEXUS-7 SECURITY PROTOCOL</label>
					</div>
					<div class="header-right">
						<div class="phase-badge @PhaseClass">
							<label class="phase-text @PhaseClass">@PhaseText</label>
						</div>
						<div class="timer-box">
							<label class="timer-value">@TimerDisplay</label>
							<label class="timer-label">REMAINING</label>
						</div>
					</div>
				</div>

				@if ( !string.IsNullOrEmpty( BodyInfo ) )
				{
					<div class="body-info-bar">
						<label class="body-info-icon">▸</label>
						<label class="body-info-text">@BodyInfo</label>
					</div>
				}
			</div>

			<!-- PLAYER GRID -->
			<div class="player-grid">
				@foreach ( var player in Players )
				{
					var cardClass = "";
					if ( !player.IsAlive ) cardClass += " is-dead";
					if ( YourVote == player.Name ) cardClass += " is-voted";
					if ( CanVote && player.IsAlive ) cardClass += " can-vote";

					var initial = player.Name.Length > 0 ? player.Name.Substring( 0, 1 ).ToUpper() : "?";

					<div class="player-card @cardClass" onclick=@( () => OnPlayerClicked( player ) )>
						<div class="card-main">
							<div class="card-avatar">
								@if ( player.SteamId > 0 )
								{
									<img src="avatar:@player.SteamId" />
								}
								else
								{
									<label class="avatar-initial">@initial</label>
								}
							</div>
							<div class="card-info">
								<label class="card-name">@player.Name</label>
								<label class="card-status @(player.IsAlive ? "alive" : "dead")">
									@(player.IsAlive ? "ACTIVE" : "ELIMINATED")
								</label>
							</div>
							@if ( player.VoteCount > 0 )
							{
								<div class="card-votes">
									<label class="vote-count">@player.VoteCount</label>
									<label class="vote-label">VOTES</label>
								</div>
							}
						</div>
						@if ( YourVote == player.Name )
						{
							<div class="your-vote-tag">
								<label class="your-vote-text">✓ YOUR VOTE</label>
							</div>
						}
					</div>
				}
			</div>

			<!-- BOTTOM BAR -->
			<div class="bottom-bar">
				<div class="toggle-hint">
					<label class="hint-text">Press</label>
					<label class="hint-key">ALT</label>
					<label class="hint-text">to toggle</label>
				</div>

				@if ( YourVote == "SKIP" )
				{
					<div class="voted-skip-tag">
						<label class="voted-skip-text">✓ VOTED TO SKIP</label>
					</div>
				}
				else if ( CanVote )
				{
					<div class="skip-button" onclick=@OnSkipClicked>
						<label class="skip-text">SKIP VOTE</label>
					</div>
				}
				else
				{
					<div class="skip-button disabled">
						<label class="skip-text">SKIP VOTE</label>
					</div>
				}
			</div>

		</div>
	</div>
</root>

@code {
	public bool IsVisible { get; set; } = true;
	public bool CanVote { get; set; } = false;
	public bool IsDiscussionPhase { get; set; } = true;
	public string YourVote { get; set; } = "";
	public string BodyInfo { get; set; } = "";
	public float TimeRemaining { get; set; } = 30f;
	public List<PlayerVoteData> Players { get; set; } = new();

	public string PhaseClass => IsDiscussionPhase ? "discussion" : "voting";
	public string PhaseText => IsDiscussionPhase ? "DISCUSSION" : "VOTING";
	public string TimerDisplay => TimeRemaining > 0 ? $"{TimeRemaining:F0}s" : "0s";

	public class PlayerVoteData
	{
		public string Name { get; set; } = "";
		public bool IsAlive { get; set; } = true;
		public int VoteCount { get; set; } = 0;
		public ulong SteamId { get; set; } = 0;
	}

	protected override void OnUpdate()
	{
		// Toggle with X key
		if ( Input.Pressed( "walk" ) )
		{
			IsVisible = !IsVisible;
		}
	}

	private void OnPlayerClicked( PlayerVoteData player )
	{
		if ( !CanVote || !player.IsAlive )
			return;

		YourVote = player.Name;

		var gameManager = Scene.GetAllComponents<GameManager>().FirstOrDefault();
		gameManager?.CastVote( player.Name );

		Log.Info( $"Voted for {player.Name}" );
	}

	private void OnSkipClicked()
	{
		if ( !CanVote )
			return;

		YourVote = "SKIP";

		var gameManager = Scene.GetAllComponents<GameManager>().FirstOrDefault();
		gameManager?.CastVote( "SKIP" );

		Log.Info( "Voted to skip" );
	}

	public void SetBodyInfo( string info )
	{
		BodyInfo = info;
	}

	public void SetTimer( float seconds )
	{
		TimeRemaining = seconds;
	}

	public void EnableVoting()
	{
		CanVote = true;
		IsDiscussionPhase = false;
	}

	public void UpdatePlayers( List<PlayerVoteData> players )
	{
		Players = players;
	}

	public void UpdateVoteCounts( Dictionary<string, int> voteCounts )
	{
		foreach ( var player in Players )
		{
			player.VoteCount = voteCounts.ContainsKey( player.Name ) ? voteCounts[player.Name] : 0;
		}
	}

	protected override int BuildHash()
	{
		var hash = System.HashCode.Combine( IsVisible, CanVote, YourVote, TimeRemaining.ToString( "F0" ), IsDiscussionPhase, BodyInfo );
		foreach ( var p in Players )
		{
			hash = System.HashCode.Combine( hash, p.Name, p.IsAlive, p.VoteCount );
		}
		return hash;
	}
}
