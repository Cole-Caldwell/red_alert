@using Sandbox;
@using Sandbox.UI;
@inherits PanelComponent

<root>
	<style>
		.ghost-indicator {
			position: absolute;
			top: 70px;
			left: 50%;
			margin-left: -90px;
			width: 180px;
			flex-direction: row;
			align-items: center;
			justify-content: center;
			gap: 8px;
			padding: 6px 16px;
			background-color: rgba(6, 8, 22, 0.5);
			border: 1px solid rgba(180, 200, 220, 0.1);
			border-radius: 4px;
			pointer-events: none;
			z-index: 50;
		}

		.ghost-indicator.hidden {
			display: none;
		}

		.ghost-icon {
			font-size: 16px;
			color: rgba(180, 200, 220, 0.35);
		}

		.ghost-text {
			font-size: 11px;
			font-weight: 700;
			font-family: Consolas;
			color: rgba(180, 200, 220, 0.3);
			letter-spacing: 3px;
		}
	</style>

	<div class="ghost-indicator @(IsVisible ? "" : "hidden")">
		<label class="ghost-icon"></label>
		<label class="ghost-text">SPECTATING</label>
	</div>
</root>

@code {
	public bool IsVisible { get; set; } = false;

	protected override void OnUpdate()
	{
		GhostIndicatorBridge.Update( Scene );
		IsVisible = GhostIndicatorBridge.IsGhost;
	}

	protected override int BuildHash()
	{
		return System.HashCode.Combine( IsVisible );
	}
}
